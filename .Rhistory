salarios_limpio <- salarios |>
# 1. Limpiamos nombres y quitamos espacios en blanco de los datos
mutate(across(everything(), as.character)) |>
mutate(across(everything(), stringr::str_squish)) |>
# 2. Renombramos de forma segura (usando los nombres que confirmaste)
rename(
comp = `Componentes.del.coste`,
sect = `Sectores.de.actividad.CNAE.2009`,
lug  = `Comunidades.y.Ciudades.Autónomas`,
valor_texto = value  # Renombramos 'value' aquí para evitar conflictos
) |>
# 3. Filtros exactos para evitar duplicados por "coincidencia parcial"
filter(lug == "Nacional") |>
filter(sect == "Industria") |>
filter(comp == "Coste laboral total") |> # Asegúrate que el texto sea EXACTO así
# 4. Cálculos numéricos y de tiempo
mutate(
salario_eur = as.numeric(valor_texto),
ANO = as.numeric(substr(Periodo, 1, 4)),
TRIM = as.numeric(substr(Periodo, 6, 7)),
tiempo = ANO + (TRIM * 0.25) - 0.25
) |>
# 5. Filtro final y limpieza de columnas
filter(ANO >= 2008 & ANO <= 2024) |>
arrange(tiempo) |>
select(Periodo, ANO, TRIM, tiempo, salario_eur)
range(salarios_limpio$ANO)
# Para ver qué opciones reales hay en tus columnas:
unique(salarios$Componentes.del.coste)
unique(salarios$Sectores.de.actividad.CNAE.2009)
unique(salarios$Comunidades.y.Ciudades.Autónomas)
salarios_limpio <- salarios |>
# 1. Limpieza inicial
mutate(across(everything(), as.character)) |>
mutate(across(everything(), stringr::str_squish)) |>
# 2. Renombrar por posición (asegurándonos de que 'value' existe)
rename(comp = 2, sect = 3, lug = 4) |>
# 3. FILTROS EXACTOS (Copiados de tu consola)
filter(lug == "Total Nacional") |>
filter(sect == "Industria") |>
filter(comp == "Coste laboral total") |>
# 4. Transformaciones numéricas
mutate(
salario_eur = as.numeric(value),
ANO = as.numeric(substr(Periodo, 1, 4)),
TRIM = as.numeric(substr(Periodo, 6, 7)),
tiempo = ANO + TRIM * 0.25 - 0.25
) |>
# 5. Filtros de fecha y selección final
filter(ANO >= 2008 & ANO <= 2024) |>
arrange(tiempo) |>
select(Periodo, ANO, TRIM, tiempo, salario_eur)
range(salarios_limpio$ANO)
range(salarios_limpio$ANO)
range(salarios_limpio$ANO)
df_final <- pib_limpio |>
inner_join(prod_filtrado, by = "tiempo") |>
inner_join(paro_limpio, by = "tiempo") |>
inner_join(salarios_limpio, by = "tiempo") |>
select(
fecha = Periodo.x,
tiempo,
pib = pib_value,
prod = value,
paro = tasa_paro,
salario = salario_eur
)
head(df_final)
tail(df_final)
View(df_final)
View(salarios)
